{
  "name": "n8n-nodes-cpfhub",
  "version": "1.0.0",
  "description": "Official CPFHub.io node for n8n — Brazilian CPF lookup API.",
  "keywords": [
    "n8n-community-node-package",
    "cpf",
    "cpfhub",
    "brasil",
    "receita-federal"
  ],
  "homepage": "https://cpfhub.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/cpfhub/n8n-nodes-cpfhub"
  },
  "license": "MIT",
  "main": "dist/nodes/CPFHub/CPFHub.node.js",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CPFHubApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CPFHub/CPFHub.node.js"
    ]
  },
  "devDependencies": {
    "n8n-workflow": "latest",
    "typescript": "^5.0.0"
  }
}
